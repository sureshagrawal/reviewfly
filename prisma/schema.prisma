// ReviewFly — Prisma schema (schema-only; runtime queries use `postgres` driver).
// Phase 0 baseline: 5 core tables required for tenant + auth + plan modeling.
// More tables added in CVL phase per SRS §8.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Industries — registry of vertical packs (academy, restaurant, salon, etc.)
// ---------------------------------------------------------------------------
model Industry {
  code        String     @id @db.VarChar(50)
  name        String     @db.VarChar(100)
  description String?
  isActive    Boolean    @default(true) @map("is_active")
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  businesses  Business[]

  @@map("industries")
}

// ---------------------------------------------------------------------------
// Plans — subscription tiers (basic/pro/max)
// ---------------------------------------------------------------------------
model Plan {
  tier             String     @id @db.VarChar(20)
  name             String     @db.VarChar(100)
  description      String?
  priceInrMonthly  Int        @map("price_inr_monthly")
  priceInrYearly   Int        @map("price_inr_yearly")
  limitsJson       Json       @map("limits_json")
  featuresJson     Json       @map("features_json")
  isActive         Boolean    @default(true) @map("is_active")
  createdAt        DateTime   @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  businesses       Business[]

  @@map("plans")
}

// ---------------------------------------------------------------------------
// Businesses — multi-tenant root entity
// ---------------------------------------------------------------------------
model Business {
  id                     String   @id @default(uuid()) @db.Uuid
  slug                   String   @unique @db.VarChar(50)
  name                   String   @db.VarChar(200)
  industryCode           String   @map("industry_code") @db.VarChar(50)
  subTemplate            String?  @map("sub_template") @db.VarChar(50)
  planTier               String   @default("trial") @map("plan_tier") @db.VarChar(20)
  status                 String   @default("trial") @db.VarChar(20) // trial | active | suspended | cancelled
  trialEndsAt            DateTime? @map("trial_ends_at") @db.Timestamptz()
  currentPeriodEnd       DateTime? @map("current_period_end") @db.Timestamptz()
  razorpayCustomerId     String?  @map("razorpay_customer_id") @db.VarChar(100)
  razorpaySubscriptionId String?  @map("razorpay_subscription_id") @db.VarChar(100)
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt              DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt              DateTime? @map("deleted_at") @db.Timestamptz()

  industry Industry      @relation(fields: [industryCode], references: [code])
  plan     Plan          @relation(fields: [planTier], references: [tier])
  users    BusinessUser[]

  @@index([slug])
  @@index([status])
  @@index([planTier])
  @@map("businesses")
}

// ---------------------------------------------------------------------------
// BusinessUsers — tenant-scoped admin/owner users
// ---------------------------------------------------------------------------
model BusinessUser {
  id              String   @id @default(uuid()) @db.Uuid
  businessId      String   @map("business_id") @db.Uuid
  email           String   @db.VarChar(255)
  passwordHash    String   @map("password_hash") @db.VarChar(255)
  role            String   @db.VarChar(20) // owner | admin | viewer
  emailVerifiedAt DateTime? @map("email_verified_at") @db.Timestamptz()
  lastLoginAt     DateTime? @map("last_login_at") @db.Timestamptz()
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz()

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, email])
  @@index([email])
  @@map("business_users")
}

// ---------------------------------------------------------------------------
// PlatformUsers — super-admins, separate from tenant users (owner-safety)
// ---------------------------------------------------------------------------
model PlatformUser {
  id              String   @id @default(uuid()) @db.Uuid
  email           String   @unique @db.VarChar(255)
  passwordHash    String   @map("password_hash") @db.VarChar(255)
  role            String   @db.VarChar(20) // platform_owner | super_admin | support | viewer
  emailVerifiedAt DateTime? @map("email_verified_at") @db.Timestamptz()
  lastLoginAt     DateTime? @map("last_login_at") @db.Timestamptz()
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz()

  @@map("platform_users")
}

// ===========================================================================
// CVL (Phase 1a) tables
// ===========================================================================

// ---------------------------------------------------------------------------
// BusinessSettings — one row per business; tenant branding + integrations
// ---------------------------------------------------------------------------
model BusinessSettings {
  businessId             String   @id @map("business_id") @db.Uuid
  displayName            String   @map("display_name") @db.VarChar(200)
  aliases                String[] @default([]) // up to 10 alternate brand names
  logoUrl                String?  @map("logo_url") @db.VarChar(500)
  brandColor             String   @default("#1a73e8") @map("brand_color") @db.VarChar(7)
  posterTagline          String?  @map("poster_tagline") @db.VarChar(200)
  googleReviewUrl        String?  @map("google_review_url") @db.VarChar(500)
  whatsappNumber         String?  @map("whatsapp_number") @db.VarChar(20)
  aiEnabled              Boolean  @default(true) @map("ai_enabled")
  sentimentGateThreshold Float    @default(0.6) @map("sentiment_gate_threshold")
  displayTimezone        String   @default("Asia/Kolkata") @map("display_timezone") @db.VarChar(50)
  hardFallback           String   @default("Great experience! Highly recommended.") @map("hard_fallback")
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt              DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  @@map("business_settings")
}

// ---------------------------------------------------------------------------
// BusinessTags — per-tenant taxonomy with aliases + content hints
// ---------------------------------------------------------------------------
model BusinessTag {
  id              String   @id @default(uuid()) @db.Uuid
  businessId      String   @map("business_id") @db.Uuid
  category        String   @db.VarChar(50) // courses | dishes | services | staff | etc.
  name            String   @db.VarChar(200)
  description     String?
  tagType         String   @default("generic") @map("tag_type") @db.VarChar(50)
  aliases         String[] @default([]) // alternate names AI may use
  contentHints    String[] @default([]) @map("content_hints") // phrases AI may embed
  metadataJson    Json     @default("{}") @map("metadata_json")
  displayOrder    Int      @default(0) @map("display_order")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz()

  @@index([businessId, category, isActive])
  @@map("business_tags")
}

// ---------------------------------------------------------------------------
// FlowSteps — per-tenant ordered list of reviewer steps
// ---------------------------------------------------------------------------
model FlowStep {
  id              String   @id @default(uuid()) @db.Uuid
  businessId      String   @map("business_id") @db.Uuid
  stepOrder       Int      @map("step_order")
  stepKey         String   @map("step_key") @db.VarChar(50)
  stepType        String   @map("step_type") @db.VarChar(30) // single_choice | multi_choice | text_short | text_long | number | rating | info_panel
  questionLabel   String   @map("question_label") @db.VarChar(500)
  helperText      String?  @map("helper_text") @db.VarChar(500)
  configJson      Json     @default("{}") @map("config_json") // step-specific config (max picks, max length, options source, etc.)
  conditionJson   Json?    @map("condition_json") // skip-if logic
  isRequired      Boolean  @default(true) @map("is_required")
  injectIntoPrompt Boolean @default(true) @map("inject_into_prompt")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  @@unique([businessId, stepKey])
  @@index([businessId, isActive, stepOrder])
  @@map("flow_steps")
}

// ---------------------------------------------------------------------------
// PromptPools — universal + per-tenant pools of uniqueness dimensions
// businessId NULL = universal entry (visible to all tenants)
// ---------------------------------------------------------------------------
model PromptPool {
  id                  String   @id @default(uuid()) @db.Uuid
  businessId          String?  @map("business_id") @db.Uuid // NULL = universal
  dimension           String   @db.VarChar(30) // opening | tone | language | emoji | structure | grammar | staff_mention | length
  value               String
  weight              Int      @default(10)
  appliesToIndustry   String?  @map("applies_to_industry") @db.VarChar(50) // NULL = all industries
  isActive            Boolean  @default(true) @map("is_active")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  @@index([businessId, dimension, isActive])
  @@index([dimension, isActive])
  @@map("prompt_pools")
}

// ---------------------------------------------------------------------------
// ReviewEvents — append-only event log per reviewer session
// PII-safe: no name/email/phone; ip_hash only
// ---------------------------------------------------------------------------
model ReviewEvent {
  id           BigInt   @id @default(autoincrement())
  businessId   String   @map("business_id") @db.Uuid
  sessionId    String   @map("session_id") @db.VarChar(40)
  eventType    String   @map("event_type") @db.VarChar(50)
  payloadJson  Json     @default("{}") @map("payload_json")
  ipHash       String?  @map("ip_hash") @db.VarChar(64)
  uaCategory   String?  @map("ua_category") @db.VarChar(20) // mobile | tablet | desktop
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@index([businessId, createdAt])
  @@index([businessId, sessionId])
  @@map("review_events")
}

// ===========================================================================
// Phase 1b — Auth & Audit
// ===========================================================================

// ---------------------------------------------------------------------------
// RefreshTokens — rotating refresh-token chain with reuse detection
// One row per issued refresh token. On refresh: mark old as used, create new.
// On reuse of an already-used token: revoke the entire chain (familyId).
// ---------------------------------------------------------------------------
model RefreshToken {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid // business_users.id
  familyId     String   @map("family_id") @db.Uuid // shared across the rotation chain
  tokenHash    String   @unique @map("token_hash") @db.VarChar(128) // sha-256 of raw token
  userAgent    String?  @map("user_agent") @db.VarChar(255)
  ipHash       String?  @map("ip_hash") @db.VarChar(64)
  usedAt       DateTime? @map("used_at") @db.Timestamptz()
  revokedAt    DateTime? @map("revoked_at") @db.Timestamptz()
  expiresAt    DateTime @map("expires_at") @db.Timestamptz()
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@index([userId])
  @@index([familyId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ---------------------------------------------------------------------------
// AuditLogs — every mutating admin action recorded for forensics
// ---------------------------------------------------------------------------
model AuditLog {
  id            BigInt   @id @default(autoincrement())
  businessId    String?  @map("business_id") @db.Uuid // null for platform-level actions
  actorUserId   String?  @map("actor_user_id") @db.Uuid
  entityType    String   @map("entity_type") @db.VarChar(50)
  entityId      String?  @map("entity_id") @db.VarChar(64)
  action        String   @db.VarChar(50) // create | update | delete | login | logout | etc.
  oldValueJson  Json?    @map("old_value_json")
  newValueJson  Json?    @map("new_value_json")
  ipHash        String?  @map("ip_hash") @db.VarChar(64)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@index([businessId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}
