# ============================================================================
# ReviewFly — Environment Variables (PLACEHOLDERS ONLY)
# ============================================================================
# Copy this file to `.env.local` for local dev. Never commit `.env.local`.
# Production values are set in the hosting provider (Vercel/Render/etc.).
# All required vars are validated at startup by lib/env.ts (Zod fail-fast).
# ============================================================================

# --- App & Runtime ---------------------------------------------------------
NODE_ENV=development                       # development | staging | production
APP_NAME=ReviewFly
APP_ENV=development                        # mirror of NODE_ENV for app logic
LOG_LEVEL=debug                            # trace | debug | info | warn | error

# --- URLs & Domains --------------------------------------------------------
APP_URL=http://localhost:3000              # public canonical URL of the app
APP_ROOT_DOMAIN=localhost                  # for subdomain resolution (reviewfly.app in prod)
OWNER_SUBDOMAIN=owner                      # platform-owner subdomain prefix
ALLOWED_ORIGINS=http://localhost:3000      # comma-separated CORS allowlist

# --- Database & Migrations -------------------------------------------------
# Native PostgreSQL local. Supabase in production (free tier).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/reviewfly
DIRECT_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/reviewfly   # bypasses pooler for migrations

# --- Auth & Token Secrets --------------------------------------------------
# Generate with: openssl rand -base64 64
JWT_ACCESS_SECRET=replace-with-64-byte-random-string
JWT_REFRESH_SECRET=replace-with-different-64-byte-random-string
JWT_ACCESS_TTL_SECONDS=900                 # 15 minutes
JWT_REFRESH_TTL_SECONDS=604800             # 7 days
BCRYPT_COST=12                             # >= 12 in production

# --- OAuth Providers (optional in MVP) -------------------------------------
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/v1/auth/google/callback

# --- Cache & Rate Limiting -------------------------------------------------
# Upstash Redis in production. Dev uses in-process adapter (NOT for serverless prod).
REDIS_URL=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
RATE_LIMIT_BACKEND=memory                  # memory | upstash

# --- Storage (logos, posters, future bill images) --------------------------
# Cloudflare R2 (S3-compatible) in production. Dev uses local filesystem.
STORAGE_BACKEND=local                      # local | r2 | s3
STORAGE_LOCAL_DIR=./.uploads
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# --- Email Provider --------------------------------------------------------
EMAIL_BACKEND=console                      # console | resend
RESEND_API_KEY=
EMAIL_FROM=noreply@reviewfly.app

# --- AI Providers ----------------------------------------------------------
AI_PROVIDERS=gemini,openai                 # comma-separated priority order
GEMINI_API_KEY=
OPENAI_API_KEY=
AI_REQUEST_TIMEOUT_MS=15000
AI_MAX_OUTPUT_TOKENS=400

# --- Payments (Phase 4+) ---------------------------------------------------
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# --- Monitoring & Observability -------------------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# --- Cron & Internal -------------------------------------------------------
CRON_SECRET=replace-with-random-token       # for /api/v1/cron/* bearer auth
