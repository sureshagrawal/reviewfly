{
  "name": "reviewfly",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-tenant SaaS for AI-generated Google reviews with sentiment gate",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "dotenv -e .env.local -- prisma studio",
    "seed": "dotenv -e .env.local -- tsx prisma/seed.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "jose": "^5.9.6",
    "next": "^16.2.6",
    "pino": "^9.5.0",
    "postgres": "^3.4.5",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@prisma/adapter-pg": "7",
    "@prisma/client": "^7.8.0",
    "@tailwindcss/postcss": "4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.2",
    "@types/pg": "8.20.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitest/ui": "^2.1.8",
    "dotenv": "17.4.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.17.0",
    "eslint-config-next": "^16.2.6",
    "pg": "8.21.0",
    "prisma": "^7.8.0",
    "tailwindcss": "4",
    "tsx": "^4.22.4",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
